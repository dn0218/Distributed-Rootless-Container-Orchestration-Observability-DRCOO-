global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'rocky_nodes'
    static_configs:
      - targets:
{% for host in groups['managed_nodes'] %}
          - '{{ hostvars[host].ansible_host }}:{{ node_exporter_port }}'
{% endfor %}
